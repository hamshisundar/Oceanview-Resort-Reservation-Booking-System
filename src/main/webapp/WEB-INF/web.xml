<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Ocean View Hotel Booking System</display-name>

    <!-- Bump this value to force browsers to load new CSS/JS (cache busting) -->
    <context-param>
        <param-name>resourceVersion</param-name>
        <param-value>2</param-value>
    </context-param>

    <!-- Context parameters for DB (override in production) -->
    <context-param>
        <param-name>db.url</param-name>
        <param-value>jdbc:mysql://localhost:3306/oceanview_db?useSSL=false&amp;serverTimezone=UTC</param-value>
    </context-param>
    <context-param>
        <param-name>db.user</param-name>
        <param-value>root</param-value>
    </context-param>
    <context-param>
        <param-name>db.password</param-name>
        <param-value></param-value>
    </context-param>
    <!-- Use built-in H2 by default so registration works without MySQL. Set to false to use MySQL (db.url, db.user, db.password). -->
    <context-param>
        <param-name>db.forceH2</param-name>
        <param-value>true</param-value>
    </context-param>

    <listener>
        <listener-class>com.oceanview.utils.DBContextListener</listener-class>
    </listener>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- DbStatusServlet is mapped via @WebServlet("/db-status") on the class; do not duplicate in web.xml -->

    <!-- Session timeout 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
