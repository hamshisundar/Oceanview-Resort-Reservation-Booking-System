@startuml Ocean View Resort - Use Case Diagram
!theme plain
title Ocean View Resort — Use Case Diagram\n(Actors: Customer, Staff, Manager; all use cases connected; include/extend used)

left to right direction
skinparam packageStyle rectangle
skinparam useCase {
  BackgroundColor<<include>> LightBlue
  BorderColor Black
}
skinparam actor {
  BackgroundColor White
  BorderColor Black
}

|System Boundary: Ocean View Reservation System|
rectangle "Ocean View Resort\nReservation System" as sys {

  ' === Guest use cases ===
  usecase (Register) as UC_Register
  usecase (Login) as UC_Login
  usecase (Browse Rooms) as UC_BrowseRooms
  usecase (View Room Details) as UC_ViewRoomDetails
  usecase (Add New Reservation) as UC_AddReservation
  usecase (Display Reservation Details) as UC_DisplayDetails
  usecase (Calculate and Print Bill) as UC_PrintBill
  usecase (View Booking History) as UC_ViewHistory
  usecase (View Help) as UC_ViewHelp
  usecase (Exit System) as UC_Exit

  ' === Admin use cases ===
  usecase (Login (Admin)) as UC_LoginAdmin
  usecase (Manage Rooms) as UC_ManageRooms
  usecase (Upload Room Images) as UC_UploadImages
  usecase (Manage Bookings) as UC_ManageBookings
  usecase (View Reports) as UC_ViewReports

  ' === Derived / sub use cases (for include) ===
  usecase (Check Availability) as UC_CheckAvail
  usecase (Calculate Total) as UC_CalcTotal
  usecase (Generate Reservation Number) as UC_GenResNum
  usecase (Validate Credentials) as UC_ValidateCred
  usecase (Retrieve Booking) as UC_RetrieveBooking
  usecase (Persist Room Data) as UC_PersistRoom
  usecase (Cancel Booking) as UC_CancelBooking
}

' === Actors (outside system): Customer, Staff, Manager ===
actor "Customer" as Customer
actor "Staff" as Staff
actor "Manager" as Manager

' === Associations: Customer → use cases ===
Customer --> UC_Register
Customer --> UC_Login
Customer --> UC_BrowseRooms
Customer --> UC_ViewRoomDetails
Customer --> UC_AddReservation
Customer --> UC_DisplayDetails
Customer --> UC_PrintBill
Customer --> UC_ViewHistory
Customer --> UC_ViewHelp
Customer --> UC_Exit

' === Associations: Staff → use cases ===
Staff --> UC_LoginAdmin
Staff --> UC_ManageBookings
Staff --> UC_UploadImages
Staff --> UC_ViewHelp
Staff --> UC_Exit

' === Associations: Manager → use cases ===
Manager --> UC_LoginAdmin
Manager --> UC_ManageRooms
Manager --> UC_UploadImages
Manager --> UC_ManageBookings
Manager --> UC_ViewReports
Manager --> UC_ViewHelp
Manager --> UC_Exit

' === Include (base ..> included) ===
UC_AddReservation ..> UC_CheckAvail : <<include>>
UC_AddReservation ..> UC_CalcTotal : <<include>>
UC_AddReservation ..> UC_GenResNum : <<include>>
UC_Login ..> UC_ValidateCred : <<include>>
UC_LoginAdmin ..> UC_ValidateCred : <<include>>
UC_DisplayDetails ..> UC_RetrieveBooking : <<include>>
UC_ManageRooms ..> UC_PersistRoom : <<include>>

' === Extend (extending ..> base) ===
UC_CancelBooking ..> UC_ViewHistory : <<extend>>
UC_PrintBill ..> UC_DisplayDetails : <<extend>>

@enduml
